[flake8]
max-line-length = 120
# E221/E272: aligned-assignment style used throughout the scrapers (selectors,
# constants). W503/W504: line-break-around-operator bikeshed. E741: short names ok.
# E203: whitespace before ':' (conflicts with black slice style).
# E402: module-level imports after sys.path.insert in api/main.py (intentional).
# E701: compact one-line `if cond: return ...` dispatch style (api/turso.py).
extend-ignore = E221,E272,W503,W504,E741,E203,E402,E701
exclude = .git,__pycache__,apps,output,logs,.pytest_cache,build,*.egg-info,.venv,venv
